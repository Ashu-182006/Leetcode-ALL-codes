class Solution {
    public int maxArea(int[] height) {
     int j=height.length-1;
      int i=0;
     int  d=0;
    
     while (i!=j){
       
         int s=((j-i)*Math.min(height[i],height[j]));
        if (s>d){
            d=s;
        }
        if(height[i]<height[j]){
            i++;
        }
        else{
            j--;
        }

     }
      return(d);  
    }
}
